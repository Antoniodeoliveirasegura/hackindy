# Supabase Configuration (REQUIRED)
# Get these from your Supabase project settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server Configuration
PORT=3000
HOST=127.0.0.1
SESSION_SECRET=your-session-secret-change-in-production

# Client App URL (for redirects)
CLIENT_APP_URL=http://localhost:5173

# Purdue Auth Mode: 'mock' for development, 'cas' for production
PURDUE_AUTH_MODE=mock

# For CAS mode (production), set these:
# PURDUE_CAS_LOGIN_URL=https://www.purdue.edu/apps/account/cas/login
# PURDUE_CAS_VALIDATE_URL=https://www.purdue.edu/apps/account/cas/serviceValidate

# Development helpers
DEV_PURDUE_EMAIL=student@purdue.edu
